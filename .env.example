# ---------------------------------------------------------------------------
# Vayu Console — backend environment
#
# Copy to `.env` and fill in. `.env` is gitignored and must never be committed.
# On Render these are set in the dashboard, not from a file.
#
#   cp .env.example .env
#
# Only DATABASE_URL is required, and only when ENVIRONMENT=production. A fresh
# clone runs with none of these set; `/health` reports what is unconfigured.
# ---------------------------------------------------------------------------

# -- Application ------------------------------------------------------------
# One of: development | staging | production
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
# One of: json | console  (use `console` locally for readable logs)
LOG_FORMAT=console

# Comma-separated list of browser origins allowed to call this API.
# Add your Vercel URL here when you deploy the frontend.
CORS_ORIGINS=http://localhost:3000

# -- Database (Supabase) ----------------------------------------------------
# Supabase dashboard → Project Settings → Database → Connection string → URI.
# Use the connection pooler URI (port 6543) for serverless, or the direct
# connection (port 5432) for migrations.
DATABASE_URL=

# -- Supabase project -------------------------------------------------------
# Supabase dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Bypasses row-level security. Server-side only — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# -- Cache ------------------------------------------------------------------
# Reserved: not connected in Phase 0.
REDIS_URL=

# -- LLM --------------------------------------------------------------------
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# -- Ground station data (CPCB via data.gov.in) -----------------------------
# https://data.gov.in — register and generate an API key.
DATA_GOV_API_KEY=

# -- NASA FIRMS (active fire / thermal anomalies) ---------------------------
# https://firms.modaps.eosdis.nasa.gov/api/map_key/
# Limit: 5000 transactions per 10-minute interval.
NASA_FIRMS_API_KEY=

# -- NASA Earthdata (satellite products) ------------------------------------
# https://urs.earthdata.nasa.gov → Generate Token. Tokens expire; regenerate.
NASA_EARTHDATA_BEARER_TOKEN=

# -- Copernicus Data Space --------------------------------------------------
# OAuth 2.0: these credentials are exchanged for a short-lived access token at
# request time. There is no static API key.
# https://dataspace.copernicus.eu
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=
