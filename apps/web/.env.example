# ---------------------------------------------------------------------------
# Vayu Console — web environment
#
# Copy to `apps/web/.env.local` and adjust. Next.js reads `.env.local` from the
# app directory, not the repository root.
#
#   cp apps/web/.env.example apps/web/.env.local
#
# NEXT_PUBLIC_* values are inlined into the browser bundle at build time.
# Never put a secret behind a NEXT_PUBLIC_ prefix — it ships to every visitor.
# ---------------------------------------------------------------------------

# Base URL of the Vayu Console API. No trailing slash.
# Local:      http://localhost:8000
# Production: https://<your-service>.onrender.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
