#!/usr/bin/env sh
#
# Blocks a commit that would track an environment file or a credential.
# Enable once per clone:  git config core.hooksPath .githooks

if [ -f scripts/check-secrets.sh ]; then
  sh scripts/check-secrets.sh || {
    echo ""
    echo "Commit blocked: see above. This repository is public — do not force past this."
    exit 1
  }
fi
